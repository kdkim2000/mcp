# Google Apps Script 웹 앱 URL (docs/ARCHITECTURE.md 참고하여 생성)
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# 기본 사용자 이메일 (tool 호출 시 email 생략하면 이 값 사용)
DEFAULT_USER_EMAIL=you@example.com

# SQLite DB 경로 (상대경로면 프로젝트 루트 기준)
DB_PATH=./data/usage.db

# 입력 검증 임계값 (log_usage)
MAX_TOKENS_PER_CALL=1000000

# Webhook 재시도 설정
SHEETS_MAX_RETRIES=3
SHEETS_RETRY_BASE_MS=1000
