{
  "name": "mcp-server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:remote": "wrangler d1 migrations apply mcp-usage --remote",
    "migrate:local": "wrangler d1 migrations apply mcp-usage --local",
    "tail": "wrangler tail --format pretty"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250512.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.0.0"
  }
}
